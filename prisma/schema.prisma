generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ProjectStatus {
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum FollowUpType {
  POLITE_REMINDER
  FIRM_REMINDER
  ESCALATION
  FINAL_NOTICE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  timezone  String   @default("UTC")
  currency  String   @default("USD")
  hourlyRate Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  clients          Client[]
  invoices         Invoice[]
  integrations     Integration[]
  complianceAlerts ComplianceAlert[]

  @@map("users")
}

model Client {
  id           String   @id @default(cuid())
  userId       String
  name         String
  email        String
  company      String?
  phone        String?
  vatNumber    String?
  country      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects         Project[]
  invoices         Invoice[]
  onboardingForms  OnboardingForm[]
  scopeCreepEvents ScopeCreepEvent[]

  @@map("clients")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(ONBOARDING)
  hourlyRate  Float?
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  githubRepo  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  scopeCreepEvents ScopeCreepEvent[]
  complianceAlerts ComplianceAlert[]

  @@map("projects")
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  projectId   String?
  number      String
  status      InvoiceStatus @default(DRAFT)
  amount      Float
  currency    String        @default("USD")
  vatRate     Float?
  vatAmount   Float?
  dueDate     DateTime
  paidAt      DateTime?
  stripeInvoiceId String?
  lineItems   Json?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  paymentFollowUps PaymentFollowUp[]

  @@map("invoices")
}

model PaymentFollowUp {
  id         String       @id @default(cuid())
  invoiceId  String
  type       FollowUpType
  sentAt     DateTime     @default(now())
  channel    String       @default("email")
  message    String
  response   String?
  opened     Boolean      @default(false)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payment_follow_ups")
}

model OnboardingForm {
  id         String   @id @default(cuid())
  clientId   String
  token      String   @unique @default(cuid())
  fields     Json
  responses  Json?
  completed  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("onboarding_forms")
}

model ScopeCreepEvent {
  id          String   @id @default(cuid())
  clientId    String
  projectId   String
  description String
  source      String
  severity    String   @default("medium")
  resolved    Boolean  @default(false)
  quoteSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("scope_creep_events")
}

model ComplianceAlert {
  id          String        @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String
  severity    AlertSeverity @default(INFO)
  region      String
  regulation  String?
  actionUrl   String?
  dismissed   Boolean       @default(false)
  createdAt   DateTime      @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("compliance_alerts")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String?
  refreshToken String?
  metadata     Json?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("integrations")
}

model AgentActivity {
  id        String   @id @default(cuid())
  userId    String
  agentType String
  action    String
  status    String   @default("success")
  details   Json?
  invoiceId String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([invoiceId])
  @@map("agent_activities")
}
